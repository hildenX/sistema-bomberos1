# Configuración de Email para envío de comprobantes
# Copia este archivo a .env y completa con tus datos

# Email de Gmail desde donde se enviarán los comprobantes
EMAIL_HOST_USER=tu_email@gmail.com

# Contraseña de aplicación (NO tu contraseña normal de Gmail)
# Consíguela en: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Opcional: Configuración de Base de Datos
DB_NAME=bomberos_db
DB_USER=root
DB_PASSWORD=tu_password
DB_HOST=localhost
DB_PORT=3306
